# Python virtual environment
.venv/
venv/
env/

# Python cache
__pycache__/
*.py[cod]
*.pyo

# Qdrant embedded vector store (rebuilt locally on first run)
qdrant_store/

# Dokument-Cache-Dateien (plain-text Extrakte)
documents/*.cache.txt

