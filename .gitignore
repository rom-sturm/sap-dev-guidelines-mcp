doc_index.json

# Eigene Guideline-Dokumente (nicht Teil des Repos)
documents/*.pdf
documents/*.txt
documents/*.md

# Lokal gecachtes Embedding-Modell (wird beim ersten Start automatisch geladen)
models/

# IDE
.vscode/
.idea/
*.code-workspace

# OS
.DS_Store
Thumbs.db
